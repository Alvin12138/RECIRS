cd ..
nano optee-fix.dts
########################################### optee-fix.dts
/dts-v1/;
/plugin/;

/ {
	fragment@0 {
		target-path = "/";

		__overlay__ {
			firmware {
				optee-fix {
					compatible = "linaro,optee-tz";
					method = "smc";
				};
			};
		};
	};
};
###########################################
./linux/scripts/dtc/dtc optee-fix.dts > optee-fix.dtbo
